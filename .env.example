# Copy this file to .env and fill in real values. .env is gitignored.
# Flask auto-loads .env on startup because python-dotenv is in
# requirements.txt, so you do not need to source it manually.

# Secret key signs the session cookie and CSRF tokens. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-long-random-string

# Google AI Studio API key for the Gemma-powered itinerary generator.
# Create a free key at https://aistudio.google.com/app/apikey and paste
# below. Without this, /itinerary/new will flash an error and refuse
# to call the AI.
GOOGLE_API_KEY=replace-me-with-google-ai-studio-key

# Pixabay API key for destination images on itinerary cards.
# Create a free key at https://pixabay.com/api/docs/ (shown at the top
# of the page once you're signed in). Without this, /api/destination_image
# returns nothing and cards fall back to loremflickr.
PIXABAY_API_KEY=replace-me-with-pixabay-api-key

# Bootstrap admin account on first run. If ADMIN_PASSWORD is unset,
# no admin is seeded — set it before your first `python app.py`, or
# create an account through /register and grant admin manually in the
# DB. We ship `admin` here so a freshly-cloned repo "just works" for
# the uni-project markers after `cp .env.example .env`; change all
# three values before any real deploy.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@smartvoyage.local
ADMIN_PASSWORD=admin

