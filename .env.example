# Copy this file to .env and fill in real values. .env is gitignored.
# Flask auto-loads .env on startup because python-dotenv is in
# requirements.txt, so you do not need to source it manually.

# Secret key signs the session cookie and CSRF tokens. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-long-random-string
